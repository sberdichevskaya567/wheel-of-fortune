{
  "semi": true,
  "tabWidth": 2,
  "printWidth": 120,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "trailingComma": "none",
  "bracketSameLine": true,

  "htmlWhitespaceSensitivity": "ignore",

  "plugins": [
    "@trivago/prettier-plugin-sort-html-attributes"
  ],

  "overrides": [
    {
      "files": "*.html",
      "options": {
        "singleQuote": false
      }
    }
  ]
}
